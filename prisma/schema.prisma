generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// -----------------------------------------------------------------------------
// BETTER AUTH USER AND SYSTEM MODELS
// -----------------------------------------------------------------------------

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String?
  image                 String?
  emailVerified         Boolean   @default(false)
  
  // Роли и Права
  role                  String    @default("USER") // USER, ADMIN
  canMakePlaylistsPublic Boolean  @default(false)
  isReadOnly            Boolean   @default(false)
  banned                Boolean   @default(false)

  // Трекинг активности
  loginCount            Int       @default(0)
  lastLoginAt           DateTime?
  totalPlayTime         Int       @default(0)
  
  // Очередь и Последнее воспроизведение
  queue                 String?   @default("[]") @db.LongText
  lastPlayedTrackId     Int?
  lastPlayedPlaylistId  String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Связи
  sessions              Session[]
  accounts              Account[]
  
  playlists             Playlist[]         @relation("UserPlaylists")
  favoriteTracks        FavoriteTrack[]
  favoritePlaylists     FavoritePlaylist[]
  favoriteArtists       FavoriteArtist[]
  trackHistory          TrackHistory[]
  playlistHistory       PlaylistHistory[]

  @@map("user") // Обязательно для better-auth (modelName: "user")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// -----------------------------------------------------------------------------
// MINGLE CONTENT MODELS
// -----------------------------------------------------------------------------

model Track {
  id          Int      @id @default(autoincrement())
  
  // Музыкальные метаданные
  title       String
  artist      String   // имя исполнителя
  src         String   // локальный относительный путь /audio/...
  fullSrc     String?  // полный путь если нужен
  cover       String
  colors      Json?    // Массив из 4-5 цветов (гекс-коды)
  
  type        String   @default("track") // Для совместимости с текущей логикой
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Связи
  playlists   PlaylistTrack[]
  favoritedBy FavoriteTrack[]
  history     TrackHistory[]
  
  @@map("track")
}

enum PlaylistCategory {
  OTHER
  SINGLE
  ALBUM
  VIBE
  PLAYLIST
  MIX
}

model Playlist {
  id             String           @id @default(cuid())
  title          String
  cover          String?
  
  type           String           @default("user") // "system" | "user"
  category       PlaylistCategory @default(PLAYLIST)
  isPublic       Boolean          @default(false)
  
  colors         Json?

  authorId       String?
  author         User?            @relation("UserPlaylists", fields: [authorId], references: [id], onDelete: SetNull)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Связи
  tracks         PlaylistTrack[]
  favoritedBy    FavoritePlaylist[]
  history        PlaylistHistory[]
  
  @@map("playlist")
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    Int
  
  order      Int      @default(0) // Для drag and drop

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId]) // Трек может быть в плейлисте только 1 раз (или можно убрать если допускаются повторы)
  @@map("playlist_track")
}

// -----------------------------------------------------------------------------
// USER FAVORITES (МЕДИАТЕКА)
// -----------------------------------------------------------------------------

model FavoriteTrack {
  id        String   @id @default(cuid())
  userId    String
  trackId   Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@map("favorite_track")
}

model FavoritePlaylist {
  id          String   @id @default(cuid())
  userId      String
  playlistId  String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([userId, playlistId])
  @@map("favorite_playlist")
}

// Избранные исполнители. Пока что артист хранится только как String в Track.
// Поэтому тут сохраняем текстовое имя артиста.
model FavoriteArtist {
  id         String   @id @default(cuid())
  userId     String
  artistName String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artistName])
  @@map("favorite_artist")
}

// -----------------------------------------------------------------------------
// USER HISTORY (История прослушиваний)
// -----------------------------------------------------------------------------

model TrackHistory {
  id          String   @id @default(cuid())
  userId      String
  trackId     Int
  playedAt    DateTime @default(now())
  listenedSec Int      @default(0)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt(sort: Desc)])
  @@map("track_history")
}

model PlaylistHistory {
  id         String   @id @default(cuid())
  userId     String
  playlistId String
  playedAt   DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt(sort: Desc)])
  @@map("playlist_history")
}
